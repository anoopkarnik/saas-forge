{
  "templateRoot": "templates/saas-boilerplate",
  "stageRoot": ".generated/saas-boilerplate",
  "overrideRoot": "template-overrides/saas-boilerplate",
  "include": [
    ".eslintrc.js",
    "apps/web",
    "apps/mobile",
    "apps/desktop",
    "package.json",
    "packages",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.json",
    "turbo.json",
    "vitest.workspace.ts"
  ],
  "exclude": [
    "apps/mobile/components/downloads",
    "apps/web/vitest-coverage-output.txt",
    "apps/web/app/api/scaffold",
    "apps/web/tests/integration/scaffoldRoute.test.ts"
  ],
  "templateOverrides": [
    "apps/desktop/src/renderer/src/components/admin/AdminCmsRoute.tsx",
    "apps/desktop/src/renderer/src/components/admin/AdminUsersRoute.tsx",
    "apps/desktop/src/renderer/src/components/home/TemplateAppSidebar.tsx",
    "apps/desktop/src/renderer/src/components/home/DashboardRoute.tsx",
    "apps/mobile/app/(home)/index.tsx",
    "apps/web/app/(home)/page.tsx",
    "apps/web/components/home/AppSidebar.tsx",
    "apps/web/middleware.ts",
    "apps/web/next.config.mjs",
    "package.json"
  ]
}
