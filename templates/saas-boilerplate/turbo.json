{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:coverage": {
      "dependsOn": [
        "^test:coverage"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "AUTH_GITHUB_CLIENT_ID",
    "AUTH_GITHUB_CLIENT_SECRET",
    "AUTH_GOOGLE_CLIENT_ID",
    "AUTH_GOOGLE_CLIENT_SECRET",
    "AUTH_LINKEDIN_CLIENT_ID",
    "AUTH_LINKEDIN_CLIENT_SECRET",
    "AI_GATEWAY_API_KEY",
    "ANTHROPIC_API_KEY",
    "BACKEND_DATABASE_URL",
    "BACKEND_HMAC_SECRET",
    "BACKEND_HMAC_SECRET_NEXT",
    "BACKEND_URL",
    "BETTER_AUTH_SECRET",
    "BLOB_READ_WRITE_TOKEN",
    "DATABASE_URL",
    "DODO_PAYMENTS_API_KEY",
    "DODO_PAYMENTS_ENVIRONMENT",
    "DODO_PAYMENTS_RETURN_URL",
    "DODO_PAYMENTS_WEBHOOK_KEY",
    "DODO_CREDITS_PRODUCT_ID",
    "DOCUMENTATION_DATABASE_ID",
    "FAQ_DATABASE_ID",
    "FEATURE_DATABASE_ID",
    "FOOTER_DATABASE_ID",
    "GA4_CREDENTIALS_JSON",
    "GA4_PROPERTY_ID",
    "GOOGLE_PAGESPEED_API_KEY",
    "HERO_DATABASE_ID",
    "LANDING_DATABASE_ID",
    "LOG_FORMAT",
    "LOG_LEVEL",
    "METRICS_ENABLED",
    "OLLAMA_BASE_URL",
    "OPENAI_API_KEY",
    "OPENAI_COMPATIBLE_BASE_URL",
    "OPENROUTER_API_KEY",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "NEXT_PUBLIC_AI_ENABLED",
    "NEXT_PUBLIC_CMS",
    "NEXT_PUBLIC_DODO_PAYMENTS_URL",
    "NEXT_PUBLIC_R2_PUBLIC_URL",
    "NEXT_PUBLIC_SUPPORT_FEATURES",
    "NEXT_PUBLIC_SUPPORT_MAIL",
    "NEXT_PUBLIC_URL",
    "N8N_SAAS_ASSISTANT_WEBHOOK_URL",
    "N8N_SUBSCRIBE_NEWSLETTER_WEBHOOK_URL",
    "NOTION_API_TOKEN",
    "PRICING_DATABASE_ID",
    "QDRANT_API_KEY",
    "QDRANT_URL",
    "R2_ACCESS_KEY_ID",
    "R2_ACCOUNT_ID",
    "R2_BUCKET_NAME",
    "R2_SECRET_ACCESS_KEY",
    "RAG_EMBEDDER",
    "RAG_VECTOR_STORE",
    "REDIS_URL",
    "RESEND_API_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "TESTIMONIAL_DATABASE_ID",
    "UPSTASH_REDIS_REST_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "VERCEL"
  ]
}
