# Runtime queries from the app. When using Prisma Accelerate, set this to the
# Accelerate proxy URL: prisma+postgres://accelerate.prisma-data.net/?api_key=...
# When NOT using Accelerate, set it to your Postgres URL (same value as DIRECT_URL).
DATABASE_URL=""

# Direct Postgres connection used by `prisma migrate`, `prisma db seed`, and
# `prisma generate`. Always a postgresql://USER:PASSWORD@HOST:5432/DBNAME URL,
# never an Accelerate URL — the Prisma CLI cannot run DDL through Accelerate.
DIRECT_URL=""
