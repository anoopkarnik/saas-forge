{
  "name": "saas-forge",
  "version": "1.2.3",
  "description": "SaaS Forge desktop application for managing your SaaS projects",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev -- --disable-dev-shm-usage",
    "package": "electron-builder",
    "build": "electron-vite build",
    "build:prod": "electron-vite build --mode production",
    "package:snap": "electron-builder --linux snap",
    "install:locally": "node ../../scripts/publish-desktop.mjs --install-locally",
    "publish:snapstore:edge": "node ../../scripts/publish-desktop.mjs --release edge",
    "publish:snapstore:stable": "node ../../scripts/publish-desktop.mjs --release stable"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-query": "^5.90.16",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "@workspace/auth": "workspace:*",
    "@workspace/database": "workspace:*",
    "@workspace/ui": "workspace:*",
    "date-fns": "^4.1.0",
    "electron-store": "^10.x",
    "express": "^5.x",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.475.0",
    "next-themes": "^0.4.6",
    "react": "^19.x",
    "react-dom": "^19.x",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.x",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.x",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.x",
    "@workspace/typescript-config": "workspace:*",
    "cross-env": "^10.1.0",
    "electron": "^36.x",
    "electron-builder": "^25.x",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "5.7.3",
    "vite": "^7.3.1"
  }
}
