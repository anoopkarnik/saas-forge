# Copy to scripts/deploy.env (gitignored) and fill in.
# scripts/deploy-backend.sh sources this file automatically when present.

# Required: GCP project + zone + instance name.
GCP_PROJECT=bayesian-labs-489523
GCP_ZONE=us-central1-a
GCP_INSTANCE=saas-forge-backend

# Optional: remote directory on the VM (default: ~/saas-forge).
# The script ships Dockerfile.backend, docker-compose.yml, docker-compose.prod.yml
# and apps/backend/ into this directory and runs docker compose from there.
REMOTE_DIR=~/saas-forge

# Optional: services to (re)start on each deploy. Defaults to api + worker.
# To deploy only the api, set: COMPOSE_SERVICES="backend-api"
COMPOSE_SERVICES="backend-api backend-worker"
