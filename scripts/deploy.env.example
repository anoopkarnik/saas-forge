# Copy to scripts/deploy.env (gitignored) and fill in.
# scripts/deploy-backend.sh sources this file automatically when present.

# --- Docker Hub (required) ---------------------------------------------------
# `docker login` once on your machine before the first deploy.

DOCKERHUB_NAMESPACE=anoopkarnik
DOCKERHUB_API_IMAGE=saas-forge-backend-api
DOCKERHUB_WORKER_IMAGE=saas-forge-backend-worker

# --- Image tag (optional) ----------------------------------------------------
# Defaults to short git SHA. Each push also retags `:latest`.
# IMAGE_TAG=v1.0.0

# --- Build platform (optional) -----------------------------------------------
# Coolify servers are almost always linux/amd64. Override if yours differs.
# BUILD_PLATFORM=linux/amd64

# --- Coolify webhooks (optional) ---------------------------------------------
# If set, the script will POST to these URLs after pushing the images so
# Coolify redeploys immediately instead of waiting for its registry watcher.
#
# Get them from Coolify: open the Application → Webhooks → Deploy URL.
# For self-hosted Coolify the URL looks like:
#   https://coolify.yourdomain.com/api/v1/deploy?uuid=<RESOURCE_UUID>&force=true
# For Coolify Cloud:
#   https://app.coolify.io/api/v1/deploy?uuid=<RESOURCE_UUID>&force=true
#
# If your webhooks require an auth token, set COOLIFY_TOKEN — the script
# sends it as `Authorization: Bearer ...`.

# COOLIFY_WEBHOOK_API=
# COOLIFY_WEBHOOK_WORKER=
# COOLIFY_TOKEN=
